# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/silkshop

# JWT Authentication
JWT_ACCESS_SECRET=your-secret-key-minimum-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:1010,http://localhost:3000

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Redis (optional - for shared rate limiting in production)
# Format: redis://:password@hostname:port/db
# If not set, in-memory storage is used (single-instance only)
# Example: REDIS_URL=redis://:mypassword@localhost:6379/0
REDIS_URL=

# Rate Limiting (all optional - defaults shown)
# RATE_LIMIT_DEFAULT=200
# RATE_LIMIT_WINDOW=1 minute
# RATE_LIMIT_AUTH=5
# RATE_LIMIT_AUTH_WINDOW=1 minute
# RATE_LIMIT_REFRESH=10
# RATE_LIMIT_REFRESH_WINDOW=1 minute
# RATE_LIMIT_CUSTOMER_AUTH=10
# RATE_LIMIT_CUSTOMER_AUTH_WINDOW=1 minute
# RATE_LIMIT_UPLOAD=10
# RATE_LIMIT_UPLOAD_WINDOW=1 minute
# RATE_LIMIT_PUBLIC_UPLOAD=5
# RATE_LIMIT_PUBLIC_UPLOAD_WINDOW=1 minute
# RATE_LIMIT_ADMIN=60
# RATE_LIMIT_ADMIN_WINDOW=1 minute
# RATE_LIMIT_CUSTOMER=60
# RATE_LIMIT_CUSTOMER_WINDOW=1 minute
# RATE_LIMIT_PRODUCTS=200
# RATE_LIMIT_PRODUCTS_WINDOW=1 minute
# RATE_LIMIT_PUBLIC_REQUESTS=10
# RATE_LIMIT_PUBLIC_REQUESTS_WINDOW=1 minute
