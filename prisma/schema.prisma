generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          Role           @default(ADMIN)
  avatar        String         @default("👤")
  phone         String?
  timezone      String         @default("Asia/Ashgabat")
  langPref      String         @default("tk")
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

// ─── Store ────────────────────────────────────────────────────────────────────

model StoreSettings {
  id        String   @id @default("singleton")
  nameTk    String   @default("SilkShop")
  nameRu    String   @default("SilkShop")
  taglineTk String   @default("Iň gowy önümler")
  taglineRu String   @default("Лучшие товары")
  email     String   @default("info@silkshop.tm")
  phone     String   @default("+993 12 123456")
  addressTk String   @default("Aşgabat, Türkmenistan")
  addressRu String   @default("Ашхабад, Туркменистан")
  currency  String   @default("USD")
  logo      String   @default("🛍️")
  updatedAt DateTime @updatedAt
}

// ─── Products ─────────────────────────────────────────────────────────────────
model Category {
  id        String     @id @default(cuid())
  nameTk    String
  nameRu    String
  parentId  String?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  products  Product[]
  createdAt DateTime   @default(now())
}

model Product {
  id            String        @id @default(cuid())
  nameTk        String
  nameRu        String
  descriptionTk String?       @db.Text // ← ADD THIS
  descriptionRu String?       @db.Text // ← ADD THIS
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id])
  image         String        @default("📦")
  imageUrl      String? // keep for backward compat (first image)
  imageUrls     String[]      @default([]) // ← NEW: multiple images
  weightG       Int?
  price         Decimal       @db.Decimal(10, 2)
  stock         Int           @default(0)
  sold          Int           @default(0)
  status        ProductStatus @default(ACTIVE)
  markup        Int           @default(50) // also add this — it's missing from schema
  options       Json          @default("[]")
  orderLines    OrderLine[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  comments      Comment[]
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

// ─── Customers ────────────────────────────────────────────────────────────────

model Customer {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  phone        String?
  address      String?
  passwordHash String?
  googleId     String?        @unique // ← add this
  status       CustomerStatus @default(ACTIVE)
  orders       Order[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  comments     Comment[]
}

enum CustomerStatus {
  ACTIVE
  BLOCKED
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id           String       @id @default(cuid())
  customerId   String
  customer     Customer     @relation(fields: [customerId], references: [id])
  lines        OrderLine[]
  total        Decimal      @db.Decimal(10, 2)
  status       OrderStatus  @default(PENDING)
  deliveryType DeliveryType @default(simple)
  homeDelivery Boolean      @default(false)
  note         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model OrderLine {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  qty       Int
  unitPrice Decimal @db.Decimal(10, 2)
  options   Json    @default("{}") // JSON object storing selected options
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeliveryType {
  simple
  fast
}

// ─── Product Requests ─────────────────────────────────────────────────────────

model ProductRequest {
  id           String               @id @default(cuid())
  nameTk       String
  nameRu       String
  description  String?
  imageUrl     String?
  contactName  String
  contactPhone String?
  contactEmail String?
  status       ProductRequestStatus @default(NEW)
  adminNote    String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

enum ProductRequestStatus {
  NEW
  SEEN
  ADDED
  REJECTED
}

// ─── Comments ────────────────────────────────────────────────────────────────

model Comment {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rating     Int // 1-5
  text       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
