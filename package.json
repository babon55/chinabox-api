{
  "name": "silkshop-api",
  "version": "1.0.0",
  "description": "SilkShop REST API — Fastify + Prisma + PostgreSQL",
  "type": "module",
  "scripts": {
    "dev":        "tsx watch src/main.ts",
    "build":      "tsc",
    "start":      "node dist/main.js",
    "db:push":    "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed":    "tsx prisma/seed.ts",
    "db:studio":  "prisma studio"
  },
  "dependencies": {
    "@fastify/cors":              "^11.2.0",
    "@fastify/helmet":            "^13.0.2",
    "@fastify/jwt":               "^10.0.0",
    "@fastify/multipart":         "^9.0.1",
    "@fastify/swagger":           "^9.4.0",
    "@prisma/client":             "^5.22.0",
    "@scalar/fastify-api-reference": "^1.25.0",
    "cloudinary":                 "^2.5.1",
    "dotenv":                     "^17.3.1",
    "fastify":                    "^5.8.2",
    "fastify-plugin":             "^5.1.0",
    "zod":                        "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "pino-pretty": "^13.1.3",
    "prisma":      "^5.22.0",
    "tsx":         "^4.21.0",
    "typescript":  "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}